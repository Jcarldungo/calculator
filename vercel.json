{
  "version": 2,
  "builds": [
    {
      "src": "src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/src/app.js"
    },
    {
      "source": "/",
      "destination": "/src/public/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/src/public/$1"
    }
  ]
}